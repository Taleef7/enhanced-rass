// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Phase D Enums ────────────────────────────────────────────────────────────

enum OrgPlan {
  FREE
  TEAM
  ENTERPRISE
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum WsRole {
  ADMIN
  EDITOR
  VIEWER
}

enum AuditOutcome {
  SUCCESS
  FAILURE
  PARTIAL
}

// ─── Phase D: Organization / Workspace / Multi-tenancy ───────────────────────

model Organization {
  id        String      @id @default(cuid())
  name      String      @unique
  plan      OrgPlan     @default(FREE)
  createdAt DateTime    @default(now())
  workspaces Workspace[]
  members   OrgMember[]
}

model OrgMember {
  id     String       @id @default(cuid())
  orgId  String
  userId String
  role   OrgRole      @default(MEMBER)
  Org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  User   User         @relation(fields: [userId], references: [id])

  @@unique([orgId, userId])
}

model Workspace {
  id              String            @id @default(cuid())
  orgId           String
  name            String
  openSearchIndex String            @unique
  quotaMb         Int               @default(500)
  usedMb          Int               @default(0)
  retentionDays   Int?
  createdAt       DateTime          @default(now())
  Org             Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members         WorkspaceMember[]
  documents       Document[]
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  role        WsRole    @default(VIEWER)
  Workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  User        User      @relation(fields: [userId], references: [id])

  @@unique([workspaceId, userId])
}

// ─── Phase D: API Key Authentication ─────────────────────────────────────────

model ApiKey {
  id        String    @id @default(cuid())
  keyHash   String    @unique
  name      String
  userId    String
  lastUsed  DateTime?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Core Models ─────────────────────────────────────────────────────────────

model User {
  id               String            @id @default(cuid())
  username         String            @unique
  password         String
  chats            Chat[]
  documents        Document[]
  knowledgeBases   KnowledgeBase[]
  kbMemberships    KBMember[]
  orgMemberships   OrgMember[]
  wsMemberships    WorkspaceMember[]
  apiKeys          ApiKey[]
  refreshTokens    RefreshToken[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

// ─── Phase D: Refresh Tokens ─────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Chat {
  id        String   @id @default(cuid())
  title     String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  documents ChatDocument[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chats")
}

model Message {
  id       String @id @default(cuid())
  text     String @db.Text
  sender   String // 'user' or 'assistant'
  chatId   String
  chat     Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sources  Json?  // Store message sources as JSON
  createdAt DateTime @default(now())

  @@map("messages")
}

model ChatDocument {
  id       String @id @default(cuid())
  name     String
  size     Int?
  chatId   String
  chat     Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  uploadedAt DateTime @default(now())

  @@map("chat_documents")
}

// ─── Phase B Models ──────────────────────────────────────────────────────────

enum DocumentStatus {
  QUEUED
  PROCESSING
  READY
  FAILED
  DELETED
}

model Document {
  id               String             @id @default(cuid())
  userId           String
  originalFilename String
  mimeType         String
  fileSizeBytes    Int
  status           DocumentStatus     @default(QUEUED)
  chunkCount       Int?
  errorMessage     String?
  openSearchIndex  String             @default("knowledge_base")
  redisKeyPrefix   String?
  ingestionJobId   String?
  kbId             String?
  workspaceId      String?
  uploadedAt       DateTime           @default(now())
  processedAt      DateTime?
  deletedAt        DateTime?
  purgedAt         DateTime?
  purgedBy         String?
  provenance       DocumentProvenance?
  User             User               @relation(fields: [userId], references: [id])
  KB               KnowledgeBase?     @relation(fields: [kbId], references: [id])
  Workspace        Workspace?         @relation(fields: [workspaceId], references: [id])
}

model DocumentProvenance {
  id               String   @id @default(cuid())
  documentId       String   @unique
  userId           String
  ingestionJobId   String
  rawFileSha256    String
  fileType         String
  fileSizeBytes    Int
  pageCount        Int?
  chunkingStrategy Json
  embeddingModel   String
  embeddingDim     Int
  chunkCount       Int
  parentCount      Int
  stagesMs         Json
  createdAt        DateTime @default(now())
  document         Document @relation(fields: [documentId], references: [id])
}

model AuditLog {
  id           String        @id @default(cuid())
  timestamp    DateTime      @default(now())
  userId       String?
  workspaceId  String?
  action       String
  resourceType String?
  resourceId   String?
  resource     String?
  ipAddress    String?
  userAgent    String?
  outcome      AuditOutcome  @default(SUCCESS)
  metadata     Json?
  createdAt    DateTime      @default(now())

  @@index([userId, timestamp])
  @@index([workspaceId, timestamp])
}

enum KBRole {
  OWNER
  EDITOR
  VIEWER
}

model KnowledgeBase {
  id              String     @id @default(cuid())
  name            String
  description     String?
  ownerId         String
  isPublic        Boolean    @default(false)
  openSearchIndex String     @unique
  embeddingModel  String
  embedDim        Int
  createdAt       DateTime   @default(now())
  documents       Document[]
  members         KBMember[]
  Owner           User       @relation(fields: [ownerId], references: [id])
}

model KBMember {
  id     String        @id @default(cuid())
  kbId   String
  userId String
  role   KBRole        @default(VIEWER)
  KB     KnowledgeBase @relation(fields: [kbId], references: [id], onDelete: Cascade)
  User   User          @relation(fields: [userId], references: [id])

  @@unique([kbId, userId])
}