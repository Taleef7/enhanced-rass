{
  "id": null,
  "uid": "rass-overview",
  "title": "RASS — Overview",
  "tags": ["rass", "overview"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(rass_requests_total[1m])) by (service)",
          "legendFormat": "{{service}}",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(rass_requests_total{status=~\"5..\"}[1m])) by (service) / sum(rate(rass_requests_total[1m])) by (service) * 100",
          "legendFormat": "{{service}} error %",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 3,
      "title": "Query Latency Percentiles (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(rass_query_latency_seconds_bucket[5m])) by (le, stage))",
          "legendFormat": "p50 {{stage}}",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(rass_query_latency_seconds_bucket[5m])) by (le, stage))",
          "legendFormat": "p95 {{stage}}",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(rass_query_latency_seconds_bucket[5m])) by (le, stage))",
          "legendFormat": "p99 {{stage}}",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 4,
      "title": "HTTP Request Duration p95 (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(rass_http_request_duration_seconds_bucket[5m])) by (le, service, route))",
          "legendFormat": "{{service}} {{route}}",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 5,
      "title": "LLM API Errors",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(increase(rass_llm_api_errors_total[1h])) by (provider)",
          "legendFormat": "{{provider}}",
          "datasource": "Prometheus"
        }
      ]
    }
  ]
}
