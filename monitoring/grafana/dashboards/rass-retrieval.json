{
  "id": null,
  "uid": "rass-retrieval",
  "title": "RASS — Retrieval Pipeline",
  "tags": ["rass", "retrieval"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Search Latency by Stage (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(rass_query_latency_seconds_bucket[5m])) by (le, stage))",
          "legendFormat": "p95 {{stage}}",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 2,
      "title": "OpenSearch Query Latency (p50/p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(rass_opensearch_query_duration_seconds_bucket[5m])) by (le, operation))",
          "legendFormat": "p50 {{operation}}",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(rass_opensearch_query_duration_seconds_bucket[5m])) by (le, operation))",
          "legendFormat": "p95 {{operation}}",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 3,
      "title": "Stream-Ask Request Rate (req/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(rass_requests_total{route=\"/stream-ask\"}[1m])) * 60",
          "legendFormat": "stream-ask req/min",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 4,
      "title": "Query Latency Heatmap",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(rass_query_latency_seconds_bucket[5m])) by (le)",
          "legendFormat": "{{le}}",
          "datasource": "Prometheus",
          "format": "heatmap"
        }
      ]
    }
  ]
}
